{
  "name": "load-available-actions",
  "version": "0.0.1",
  "private": false,
  "description": "GitHub Action to load all available actions for an organization or user",
  "main": "dist/main.js",
  "scripts": {
    "esbuild": "esbuild src/main.ts --bundle --outdir=dist --platform=node --external:vscode --external:@vscode/test-electron --external:jest",
    "build": "npm run esbuild",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "npm run esbuild",
    "test": "jest",
    "all": "npm run esbuild && npm run test # && npm run lint"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rajbos/github-action-load-available-actions.git"
  },
  "keywords": [
    "GitHub Actions",
    "load available actions from GitHub organization"
  ],
  "author": "@rajbos",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "moment": "^2.30.1",
    "node-fetch": "^3.3.2",
    "octokit": "^5.0.5",
    "string-sanitizer": "^2.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@typescript-eslint/parser": "^8.62.1",
    "@babel/core": ">=7.29.6",
    "@vercel/ncc": "^0.44.1",
    "ansi-regex": ">=6.2.2",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^29.15.4",
    "jest": "^30.4.2",
    "js-yaml": "^5.2.1",
    "prettier": "3.9.4",
    "tmpl": ">=1.0.5",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "fsevents": "^2.3.3"
  },
  "overrides": {
    "js-yaml": "^5.2.1",
    "minimatch@3.1.5": {
      "brace-expansion": "^1.1.16"
    },
    "minimatch@9.0.9": {
      "brace-expansion": "^2.1.2"
    },
    "minimatch@10.2.5": {
      "brace-expansion": "^5.0.7"
    }
  }
}
